# Copier ce fichier en ".env" (jamais commité, voir .gitignore) et renseigner les vraies valeurs.

# --- Django ---
SECRET_KEY=change-moi-avec-une-cle-aleatoire-longue
DEBUG=True

# --- Base de données (dev) ---
DB_NAME=stockmaster
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Redis (Celery + cache) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Tunnel ngrok pour tester la PWA sur un téléphone (dev uniquement) ---
# Hôte ngrok exact (sans https://), ex: turbulent-army-uncle.ngrok-free.dev
NGROK_HOST=

# --- Email (SMTP Gmail) ---
# IMPORTANT : utiliser un "mot de passe d'application" Gmail dédié, jamais le mot de passe du compte.
# Si ce mot de passe a déjà été exposé (committé en clair), révoquez-le et générez-en un nouveau.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Script create_superadmin.py ---
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# --- Production uniquement (config.settings.prod) ---
ALLOWED_HOSTS=stockmaster.example.com
CORS_ALLOWED_ORIGINS=https://stockmaster.example.com
CSRF_TRUSTED_ORIGINS=https://stockmaster.example.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
